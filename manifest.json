{
  "manifest_version": 3,
  "name": "Bitbucket Image Diff Heatmap",
  "version": "1.0.0",
  "author": "Mintaras",
  "description": "Adds heatmap visualization and slider comparison to image diffs in Bitbucket pull requests",
  "content_scripts": [
    {
      "matches": ["https://bitbucket.org/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://bitbucket.org/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
